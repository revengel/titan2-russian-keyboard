                    <TextView android:text="P\nп" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                </TableRow>
            </TableLayout>
        </HorizontalScrollView>

        <!-- Средний ряд -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Средний ряд"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp">

            <TableLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:stretchColumns="0,1,2,3,4,5,6,7,8">

                <TableRow>
                    <TextView android:text="A\nа" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="S\nс" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="D\nд" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="F\nф" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="G\nг" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="H\nч" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="J\nь" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="K\nк" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="L\nл" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                </TableRow>
            </TableLayout>
        </HorizontalScrollView>

        <!-- Нижний ряд -->
