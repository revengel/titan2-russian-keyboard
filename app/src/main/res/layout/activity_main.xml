                android:layout_height="wrap_content"
                android:stretchColumns="0,1,2,3,4,5,6,7,8">

                <TableRow>
                    <TextView android:text="A\nф" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
