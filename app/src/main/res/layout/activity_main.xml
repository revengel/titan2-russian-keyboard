                    <TextView android:text="F\nа" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="G\nп" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="H\nр" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="J\nо" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="K\nл" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="L\nд" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                </TableRow>
            </TableLayout>
        </HorizontalScrollView>

        <!-- Нижний ряд -->
