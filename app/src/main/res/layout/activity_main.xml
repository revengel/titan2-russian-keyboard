                    <TextView android:text="U\nу" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
                    <TextView android:text="I\nи" android:gravity="center" android:padding="6dp" android:background="@android:drawable/editbox_background" android:minWidth="36dp" />
