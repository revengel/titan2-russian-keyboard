<?xml version="1.0" encoding="utf-8"?>
<!--
    XML-шаблон главного экрана приложения.
    Описывает визуальное расположение элементов на экране.
-->
<!-- ScrollView — прокрутка на маленьких экранах -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <!-- LinearLayout — контейнер, располагающий элементы вертикально -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Titan2 Russian Keyboard"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <!-- Инструкция -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите раскладку:\nНастройки → Язык и ввод → Физическая клавиатура"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <!-- ========================================= -->
        <!-- ЙЦУКЕН -->
        <!-- ========================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Russian (ЙЦУКЕН)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <!-- Верхний ряд -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Верхний ряд"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

