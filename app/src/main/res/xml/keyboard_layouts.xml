<?xml version="1.0" encoding="utf-8"?>
<!--
    Список раскладок физической клавиатуры.
    Android читает этот файл через meta-data в манифесте.
    Каждая раскладка ссылается на .kcm-файл в res/raw/.
-->
<keyboard-layouts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Стандартная русская раскладка (ЙЦУКЕН) -->
    <keyboard-layout
        android:name="keyboard_layout_russian_qwerty"
        android:label="@string/layout_russian_qwerty"
        android:keyboardLayout="@raw/titan2_russian_qwerty" />
    <!-- Русская транслит-раскладка (фонетическая) -->
    <keyboard-layout
        android:name="keyboard_layout_russian_translit"
        android:label="@string/layout_russian_translit"
        android:keyboardLayout="@raw/titan2_russian_translit" />
</keyboard-layouts>
